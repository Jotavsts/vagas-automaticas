# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vagas_automaticas

# API Keys
CLAUDE_API_KEY=your_claude_api_key

# Server
PORT=5000
NODE_ENV=development

# Auth (defina um valor longo e aleatório no seu .env real, nunca versione o valor real)
JWT_SECRET=change_me_to_a_long_random_string

# Job Scraping
INDEED_BASE_URL=https://www.indeed.com
REMOTAR_BASE_URL=https://remotar.com.br

# Coleta automática de vagas (expressão cron). Default: a cada 3 horas.
# Use 'off' pra desativar. Ex: '0 8,20 * * *' = 8h e 20h todo dia.
COLLECT_CRON=0 */3 * * *

# CORS
FRONTEND_URL=http://localhost:5173
